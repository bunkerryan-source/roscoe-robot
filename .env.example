# Telegram bot — from BotFather, locked to this user
BOT_TOKEN=
MY_TELEGRAM_ID=
WEBHOOK_SECRET=

# Supabase — service role key (server-side only, never client-side)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=

# Dropbox — refresh-token OAuth flow
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# Anthropic — classifier model (Haiku 4.5)
ANTHROPIC_API_KEY=

# OpenAI — Whisper voice transcription only
OPENAI_API_KEY=

# Todoist — single-user personal API token. Project IDs are the long
# integer in the Todoist project URL (https://app.todoist.com/app/project/<id>).
TODOIST_API_TOKEN=
TODOIST_PROJECT_ACUTE=
TODOIST_PROJECT_ABP=
TODOIST_PROJECT_LAKE_ARROWHEAD=
TODOIST_PROJECT_CHURCH=
TODOIST_PROJECT_CLAUDE_BUILD=
TODOIST_PROJECT_DESIGN=
TODOIST_PROJECT_PERSONAL=

# Obsidian vault — relative to Dropbox app folder root
OBSIDIAN_VAULT_DROPBOX_PATH=/personal-os
